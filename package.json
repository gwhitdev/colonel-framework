{
  "name": "colonel",
  "module": "examples/web/src/index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun --watch examples/web/src/index.ts",
    "test": "bun run test:framework",
    "test:framework": "bun test packages/framework/src",
    "test:parity": "bun scripts/check-template-parity.ts",
    "test:smoke": "bun scripts/smoke-create-colonel.ts",
    "test:commands": "bun scripts/check-scaffold-command-consistency.ts",
    "test:versions": "bun scripts/check-version-alignment.ts",
    "test:milestone2": "bun run test:framework && bun run test:parity && bun run test:smoke",
    "test:release": "bun run test:versions && bun run test:commands"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ejs": "^3.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ejs": "^5.0.1"
  }
}
